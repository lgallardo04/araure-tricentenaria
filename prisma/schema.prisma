generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Usuarios ────────────────────────────────────────────────

model User {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  password        String
  role            UserRole   @default(JEFE_CALLE)
  phone           String?
  cedula          String?
  active          Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  comunidadId     String?
  callesAsignadas Calle[]
  familiasAuditadas Familia[] @relation("UsuarioAprobador")
  comunidad       Comunidad? @relation("JefeComunidadUsuario", fields: [comunidadId], references: [id])

  @@index([role])
  @@index([comunidadId])
  @@index([email])
}

// ─── Geografía ───────────────────────────────────────────────

model Comunidad {
  id             String   @id @default(cuid())
  nombre         String
  descripcion    String?
  sector         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  calles         Calle[]
  jefesComunidad User[]   @relation("JefeComunidadUsuario")
}

model Calle {
  id              String    @id @default(cuid())
  nombre          String
  avenida         String?
  puntoReferencia String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  comunidadId     String
  jefeCalleId     String?
  comunidad       Comunidad @relation(fields: [comunidadId], references: [id], onDelete: Cascade)
  jefeCalle       User?     @relation(fields: [jefeCalleId], references: [id])
  familias        Familia[]

  @@index([comunidadId])
  @@index([jefeCalleId])
}

// ─── Familia (tabla central, ahora liviana) ──────────────────

model Familia {
  id              String          @id @default(cuid())
  calleId         String
  estado          EstadoFamilia   @default(PENDIENTE)
  aprobadoPorId   String?
  fechaAprobacion DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  calle           Calle           @relation(fields: [calleId], references: [id], onDelete: Cascade)
  aprobadoPor     User?           @relation("UsuarioAprobador", fields: [aprobadoPorId], references: [id])

  vivienda        Vivienda?
  programaSocial  ProgramaSocial?
  personas        Persona[]

  @@index([calleId])
  @@index([estado])
}

// ─── Vivienda (1:1 con Familia) ─────────────────────────────

model Vivienda {
  id                   String             @id @default(cuid())
  familiaId            String             @unique
  direccion            String
  tipo                 String
  tenencia             String
  materialConstruccion String?
  cantidadHabitaciones Int?
  cantidadBanos        Int?
  observaciones        String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  familia              Familia            @relation(fields: [familiaId], references: [id], onDelete: Cascade)
  servicios            ServicioVivienda[]
}

// ─── Servicios de Vivienda (N:1 con Vivienda) ───────────────

model ServicioVivienda {
  id          String       @id @default(cuid())
  viviendaId  String
  tipo        TipoServicio
  estado      String

  vivienda    Vivienda     @relation(fields: [viviendaId], references: [id], onDelete: Cascade)

  @@unique([viviendaId, tipo])
  @@index([viviendaId])
}

// ─── Programas Sociales (1:1 con Familia) ────────────────────

model ProgramaSocial {
  id                 String   @id @default(cuid())
  familiaId          String   @unique
  carnetPatria       Boolean  @default(false)
  codigoCarnetPatria String?
  recibeClap         Boolean  @default(false)
  otrosBeneficios    String?
  ingresoFamiliar    String?

  familia            Familia  @relation(fields: [familiaId], references: [id], onDelete: Cascade)
}

// ─── Persona (unifica Jefe de Familia + Miembros) ────────────

model Persona {
  id               String          @id @default(cuid())
  familiaId        String
  esJefe           Boolean         @default(false)
  nombre           String
  cedula           String?
  nacionalidad     String          @default("V")
  fechaNacimiento  String
  genero           String
  parentesco       String?
  estadoCivil      String?
  telefono         String?
  email            String?
  escolaridad      String?
  ocupacion        String?
  lugarTrabajo     String?
  enfermedad       String?
  pensionado       Boolean         @default(false)
  discapacidad     Boolean         @default(false)
  tipoDiscapacidad String?
  embarazada       Boolean         @default(false)
  lactancia        Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  familia          Familia         @relation(fields: [familiaId], references: [id], onDelete: Cascade)
  registrosSalud   RegistroSalud[]

  @@index([familiaId])
  @@index([cedula])
  @@index([esJefe])
  @@index([nombre])
}

// ─── Salud ───────────────────────────────────────────────────

model Enfermedad {
  id          String          @id @default(cuid())
  nombre      String          @unique
  tipo        String
  descripcion String?
  createdAt   DateTime        @default(now())
  registros   RegistroSalud[]
}

model Medicamento {
  id              String          @id @default(cuid())
  nombre          String          @unique
  principioActivo String
  presentacion    String?
  unidad          String?
  descripcion     String?
  createdAt       DateTime        @default(now())
  registros       RegistroSalud[]
}

model RegistroSalud {
  id            String       @id @default(cuid())
  personaId     String
  enfermedadId  String
  medicamentoId String?
  dosis         String?
  frecuencia    String?
  cantidadMes   Float?
  fechaInicio   String?
  fechaFin      String?
  activo        Boolean      @default(true)
  severidad     String?
  observaciones String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  persona       Persona      @relation(fields: [personaId], references: [id], onDelete: Cascade)
  enfermedad    Enfermedad   @relation(fields: [enfermedadId], references: [id], onDelete: Cascade)
  medicamento   Medicamento? @relation(fields: [medicamentoId], references: [id])

  @@index([personaId])
  @@index([enfermedadId])
  @@index([medicamentoId])
  @@index([activo])
}

// ─── Enums ───────────────────────────────────────────────────

enum UserRole {
  ADMIN
  JEFE_COMUNIDAD
  JEFE_CALLE
}

enum EstadoFamilia {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum TipoServicio {
  AGUA
  ELECTRICIDAD
  GAS
  INTERNET
  ASEO
  TELEFONO
}
