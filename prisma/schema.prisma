generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String     @id @default(cuid())
  name              String
  email             String     @unique
  password          String
  role              UserRole   @default(JEFE_CALLE)
  phone             String?
  cedula            String?
  active            Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  comunidadId       String?
  callesAsignadas   Calle[]
  familiasAuditadas Familia[]  @relation("UsuarioAprobador")
  comunidad         Comunidad? @relation("JefeComunidadUsuario", fields: [comunidadId], references: [id])

  @@index([role])
  @@index([comunidadId])
  @@index([email])
}

model Comunidad {
  id             String   @id @default(cuid())
  nombre         String
  descripcion    String?
  sector         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  calles         Calle[]
  jefesComunidad User[]   @relation("JefeComunidadUsuario")
}

model Calle {
  id              String    @id @default(cuid())
  nombre          String
  avenida         String?
  puntoReferencia String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  comunidadId     String
  jefeCalleId     String?
  comunidad       Comunidad @relation(fields: [comunidadId], references: [id], onDelete: Cascade)
  jefeCalle       User?     @relation(fields: [jefeCalleId], references: [id])
  familias        Familia[]

  @@index([comunidadId])
  @@index([jefeCalleId])
}

model Familia {
  id                   String          @id @default(cuid())
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  direccion            String
  tipoVivienda         String
  tenencia             String
  materialConstruccion String?
  cantidadHabitaciones Int?
  cantidadBanos        Int?
  observaciones        String?
  servicioAgua         String?
  servicioElectricidad String?
  servicioGas          String?
  servicioInternet     String?
  servicioAseo         String?
  servicioTelefono     String?
  carnetPatria         Boolean         @default(false)
  codigoCarnetPatria   String?
  recibeClap           Boolean         @default(false)
  otrosBeneficios      String?
  ingresoFamiliar      String?
  jfNombre             String
  jfCedula             String
  jfNacionalidad       String          @default("V")
  jfFechaNac           String
  jfGenero             String
  jfEstadoCivil        String?
  jfTelefono           String?
  jfEmail              String?
  jfEscolaridad        String?
  jfOcupacion          String?
  jfLugarTrabajo       String?
  jfPensionado         Boolean         @default(false)
  jfDiscapacidad       Boolean         @default(false)
  jfTipoDiscapacidad   String?
  jfEnfermedad         String?
  jfEmbarazada         Boolean         @default(false)
  jfLactancia          Boolean         @default(false)
  calleId              String
  estado               EstadoFamilia   @default(PENDIENTE)
  aprobadoPorId        String?
  fechaAprobacion      DateTime?
  aprobadoPor          User?           @relation("UsuarioAprobador", fields: [aprobadoPorId], references: [id])
  calle                Calle           @relation(fields: [calleId], references: [id], onDelete: Cascade)
  miembros             Miembro[]
  registrosSalud       RegistroSalud[]

  @@index([calleId])
  @@index([jfCedula])
  @@index([jfNombre])
}

model Miembro {
  id               String          @id @default(cuid())
  nombre           String
  cedula           String?
  nacionalidad     String          @default("V")
  fechaNacimiento  String
  genero           String
  parentesco       String
  estadoCivil      String?
  escolaridad      String?
  ocupacion        String?
  lugarTrabajo     String?
  salud            String?
  pensionado       Boolean         @default(false)
  discapacidad     Boolean         @default(false)
  tipoDiscapacidad String?
  embarazada       Boolean         @default(false)
  lactancia        Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  familiaId        String
  familia          Familia         @relation(fields: [familiaId], references: [id], onDelete: Cascade)
  registrosSalud   RegistroSalud[]

  @@index([familiaId])
  @@index([cedula])
}

model Enfermedad {
  id          String          @id @default(cuid())
  nombre      String          @unique
  tipo        String
  descripcion String?
  createdAt   DateTime        @default(now())
  registros   RegistroSalud[]
}

model Medicamento {
  id              String          @id @default(cuid())
  nombre          String          @unique
  principioActivo String
  presentacion    String?
  unidad          String?
  descripcion     String?
  createdAt       DateTime        @default(now())
  registros       RegistroSalud[]
}

model RegistroSalud {
  id            String       @id @default(cuid())
  familiaId     String?
  miembroId     String?
  enfermedadId  String
  medicamentoId String?
  dosis         String?
  frecuencia    String?
  cantidadMes   Float?
  fechaInicio   String?
  fechaFin      String?
  activo        Boolean      @default(true)
  severidad     String?
  observaciones String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  enfermedad    Enfermedad   @relation(fields: [enfermedadId], references: [id], onDelete: Cascade)
  familia       Familia?     @relation(fields: [familiaId], references: [id], onDelete: Cascade)
  medicamento   Medicamento? @relation(fields: [medicamentoId], references: [id])
  miembro       Miembro?     @relation(fields: [miembroId], references: [id], onDelete: Cascade)

  @@index([familiaId])
  @@index([miembroId])
  @@index([enfermedadId])
  @@index([medicamentoId])
  @@index([activo])
}

enum UserRole {
  ADMIN
  JEFE_COMUNIDAD
  JEFE_CALLE
}

enum EstadoFamilia {
  PENDIENTE
  APROBADA
  RECHAZADA
}
